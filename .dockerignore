# ============================================================================
# FraudSentinel — files excluded from Docker build context
# ============================================================================
# Anything matched here is not sent to Docker daemon during build,
# making builds faster and final images smaller.
# ============================================================================

# ---- Python build artifacts ----
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
*.egg
build/
dist/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# ---- Virtual environments ----
.venv/
venv/
env/
ENV/

# ---- IDEs ----
.vscode/
.idea/
*.swp
*.swo

# ---- OS ----
.DS_Store
Thumbs.db

# ---- Git ----
.git/
.gitignore
.gitattributes

# ---- Secrets — NEVER ship to a public Docker image ----
.env
.env.local
.env.*.local
*.pem
*.key

# ---- Notebooks (development only — not needed in production) ----
notebooks/
*.ipynb
.ipynb_checkpoints/

# ---- MLflow tracking (development artifact) ----
mlruns/
mlflow.db

# ---- Raw / intermediate data (too large; demo data is shipped separately) ----
data/raw/
data/processed/
data/features/

# ---- Test artifacts ----
tests/
test_*.py
*_test.py
.coverage
htmlcov/

# ---- Diagnostic scripts (developer-only debugging tools) ----
diag_*.py

# ---- Documentation source (built docs, not source) ----
docs/_build/
site/

# ---- Logs ----
*.log
logs/

# ---- Backups ----
*.bak
*.old
README.md.backup
README.md.old

# ---- HF/Streamlit Cloud artifacts not needed in container ----
.streamlit/secrets.toml

# ---- Keep these in the build (explicitly NOT excluded): ----
# data/samples/         (10K demo dataset)
# data/fraud_cases/     (377-pattern library)
# models/               (trained XGBoost + LSTM + ChromaDB)
# src/                  (application code)
# requirements-hf.txt   (production deps)
# Dockerfile            (this file references it)
# README_HF.md          (HF Spaces homepage)
