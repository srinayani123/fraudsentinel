# Anthropic API key for the agentic investigation layer
# Get one at https://console.anthropic.com
# In production (HF Spaces), users provide this through the UI (BYOK)
ANTHROPIC_API_KEY=

# Model to use for agents
ANTHROPIC_MODEL=claude-sonnet-4-5

# Optional: Kaggle credentials (only needed for offline pipeline data download)
# Alternative to ~/.kaggle/kaggle.json
KAGGLE_USERNAME=
KAGGLE_KEY=

# MLflow tracking URI (default: local ./mlruns)
MLFLOW_TRACKING_URI=./mlruns
